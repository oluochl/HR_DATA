   "source": [
    "list = [23, 8, 42, 71, 15]\n",
    "#print(list)\n",
    "list.sort()\n",
    "print(list)\n",
    "if len(list)%2 == 0:\n",
    "    #print(\"This list is even\")\n",
    "    print((list[len(list)//2] + list[(len(list)//2)-1])/2)\n",
    "else:\n",
    "    #print(\"This list is odd\")\n",
    "    print(list[len(list)//2])\n",
    "\n"
   ]
  }
